# 数据库（可选，默认 SQLite）
# 本机开发请用相对路径（在 backend 目录下执行 uvicorn）：
# DATABASE_URL=sqlite:///./supply_chain.db
# 切勿把 Docker 专用的 sqlite:////data/supply_chain.db 抄到 Windows 本机，会导致无法启动。

# JWT 密钥（生产环境务必修改）
# SECRET_KEY=your-secret-key-change-in-production

# CORS：是否额外允许常见内网 IPv4 来源（192.168/10/172.16-31）访问前端 dev server
# 生产环境建议设为 false，并只用 CORS_ORIGINS 白名单
# CORS_ALLOW_PRIVATE_NETWORKS=true

# 逗号分隔的额外来源（会与默认列表合并）
# CORS_ORIGINS=http://localhost:5173,http://192.168.1.10:5173

# LLM 智能体（可选，不配置则走规则引擎）
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://127.0.0.1:11434
# LLM_MODEL=qwen2:7b
# LLM_API_KEY=

# Standalone IDS bridge
# IDS_STANDALONE_ENABLED=true
# IDS_STANDALONE_BASE_URL=http://127.0.0.1:8170
# IDS_STANDALONE_TIMEOUT_SECONDS=8
# IDS_STANDALONE_INTEGRATION_TOKEN=replace-with-shared-token
# IDS_STANDALONE_SOURCE_SYSTEM=campus_supply_chain_site
