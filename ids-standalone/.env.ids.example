IDS_DATABASE_URL=sqlite:////data/ids.db
IDS_SECRET_KEY=change-this-ids-secret-in-production
IDS_DEFAULT_ADMIN_USERNAME=ids_admin
IDS_DEFAULT_ADMIN_PASSWORD=123456
IDS_DEFAULT_ADMIN_REAL_NAME=IDS Admin
IDS_ACCEPTED_UPLOAD_DIR=/data/uploads/accepted
IDS_QUARANTINE_DIR=/data/quarantine
IDS_REPORT_DIR=/data/reports
IDS_OPERATOR_STATE_DIR=/data/state

IDS_AI_ANALYSIS=true
IDS_BLOCK_THRESHOLD=70
IDS_INTEGRATION_TOKEN=
IDS_GATEWAY_DEFAULT_PORT=8188
IDS_GATEWAY_FRONTEND_BASE_URL=http://127.0.0.1:5173
IDS_GATEWAY_BACKEND_BASE_URL=http://127.0.0.1:8166
IDS_GATEWAY_SITE_MAP=[]
IDS_GATEWAY_PORT_MAP=[]

# Example for two-machine / two-site deployment:
# IDS machine: 10.134.32.142
# Web machine: 10.134.32.132
# IDS_GATEWAY_FRONTEND_BASE_URL=http://10.134.32.132:5173
# IDS_GATEWAY_BACKEND_BASE_URL=http://10.134.32.132:8166
# IDS_GATEWAY_PORT_MAP=[{"site_key":"site2","display_name":"site2","ingress_port":8288,"frontend_base_url":"http://10.134.32.132:5273","backend_base_url":"http://10.134.32.132:8266"}]

LLM_PROVIDER=deepseek
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-chat

IDS_CORS_ORIGINS=http://localhost:5175,http://127.0.0.1:5175,http://localhost:8081,http://127.0.0.1:8081

# Optional one-time migration source for the legacy monolith
# IDS_LEGACY_MONOLITH_ROOT=../gongyinglian/workspace/CampusSupplyChainSecurityPlatform
# IDS_LEGACY_SOURCE_DB=../gongyinglian/workspace/CampusSupplyChainSecurityPlatform/backend/supply_chain.db
# IDS_LEGACY_MONOLITH_ROOT=../CampusSupplyChainSecurityPlatform
# IDS_LEGACY_SOURCE_DB=../CampusSupplyChainSecurityPlatform/backend/supply_chain.db
