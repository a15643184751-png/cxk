# ========== 推镜像到仓库时（与 docker compose build / push 一起用）==========
# 复制为 .env 或手动 export 后再执行 push-docker.ps1
#
# Docker Hub 示例：
# BACKEND_IMAGE=你的用户名/campus-supply-backend:latest
# FRONTEND_IMAGE=你的用户名/campus-supply-frontend:latest
#
# 阿里云等私有仓库：
# BACKEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/命名空间/campus-supply-backend:latest
# FRONTEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/命名空间/campus-supply-frontend:latest

# ========== 运行容器时的密钥（不要提交到 Git；不要写进 Dockerfile）==========
# 在「部署服务器」上建 .env，与 docker-compose.yml 同目录，docker compose 会自动读取
#
# JWT 密钥（必改）：随机长字符串
# SECRET_KEY=
#
# 是否启用 IDS 的 LLM 研判（需要可访问的大模型与密钥）；默认建议 false，避免无密钥时误配
# IDS_AI_ANALYSIS=false
#
# 仅当 IDS_AI_ANALYSIS=true 且你确实要接大模型时再填（勿泄露）
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://ollama主机:11434
# LLM_API_KEY=
# LLM_MODEL=qwen2:7b
